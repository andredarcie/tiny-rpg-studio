{
  "productName": "Tiny RPG Studio",
  "version": "1.3.0",
  "identifier": "com.andredarcie.tinyrpgstudio",
  "build": {
    "frontendDist": "../docs"
  },
  "app": {
    "windows": [
      {
        "title": "Tiny RPG Studio",
        "width": 1280,
        "height": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
